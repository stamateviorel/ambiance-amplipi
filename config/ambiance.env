# ambiance-amplipi runtime mode — the ONE file the cutover flips.
# Read by ambiance.service + ambiance-display.service via EnvironmentFile.
#
# Phase 0 (safe, current): Mock preamp, dry audio — nothing touches live audio/I2C.
# CUTOVER flips these two (only after amplipi.service is stopped — rt.Rpi() resets preamps):
#     AMBIANCE_HW=rpi   AMBIANCE_DRY=0
AMBIANCE_DIR=/home/pi/ambiance-amplipi
AMBIANCE_HW=mock
AMBIANCE_DRY=1
AMBIANCE_PORT=8080
